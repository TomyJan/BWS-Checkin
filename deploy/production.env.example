# BWS Checkin 生产环境配置模板。
# 该文件只放占位值，不要把真实密钥提交到仓库。
#
# 适用方式：
# - systemd：EnvironmentFile=/path/to/production.env
# - Docker / Compose：作为 env_file 使用

BWS_ADDR=:8080
BWS_DB=/var/lib/bws-checkin/bws.db
BWS_UPLOAD_DIR=/var/lib/bws-checkin/uploads
BWS_PUBLIC_BASE=https://bws.example.com

# 生产环境必须关闭开发登录。
BWS_DEV_AUTH=0

# HTTPS 部署建议启用 Secure Cookie。
BWS_COOKIE_SECURE=1
BWS_COOKIE_SAMESITE=lax
BWS_SESSION_MAX_AGE=2592000
BWS_SESSION_SECRET=<replace-with-random-session-secret>

# 启用 B 站扫码绑定和 BWS 真实数据同步。
BWS_BILIBILI_LOGIN_ENABLED=1
BWS_BILIBILI_COOKIE_SECRET=<replace-with-random-bilibili-cookie-secret>

# 登录渠道：
# - qq：QQ OAuth，回调地址为 https://bws.example.com/api/v1/auth/oauth/qq/callback
# - casdoor：自定义 OIDC provider，issuer 为 https://auth.amoe.cc，
#   回调地址为 https://bws.example.com/api/v1/auth/oauth/casdoor/callback
BWS_OAUTH_PROVIDERS=[{"id":"qq","name":"QQ登录","type":"qq","authUrl":"https://graph.qq.com/oauth2.0/authorize","tokenUrl":"https://graph.qq.com/oauth2.0/token","userInfoUrl":"https://graph.qq.com/user/get_user_info","clientId":"<qq-client-id>","clientSecret":"<qq-client-secret>","redirectUrl":"https://bws.example.com/api/v1/auth/oauth/qq/callback"},{"id":"casdoor","name":"AMOE认证","type":"oidc","issuerUrl":"https://auth.amoe.cc","clientId":"<casdoor-client-id>","clientSecret":"<casdoor-client-secret>","redirectUrl":"https://bws.example.com/api/v1/auth/oauth/casdoor/callback"}]
